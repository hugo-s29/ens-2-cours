</Group><CodeEditor-ExecGroup view="presentation" labelreference="L28" drawlabel="true" applyint="true" applyrational="true" display="code"><EC-CodeEditor id="CodeEditRegion1" expanded="true" visible="true" pixel-width="500" pixel-height="200" code-language="text/maple" autofit="true" wrapping="true" show-border="true" code-line-numbers="true">magic := proc(A)
	local N, gen, u, v, res, last, new, i:
	N := RowDimension(A):
	gen := Generate(integer, makeproc = true):
	u := Vector[row](N, gen):
	v := Vector[column](N, gen):
	res := [u . v]:
	last := v:
	for i from 1 to 2*N do
