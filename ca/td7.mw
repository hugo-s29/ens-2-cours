</Group><CodeEditor-ExecGroup view="presentation" labelreference="L99" drawlabel="true" applyint="true" applyrational="true" display="code"><EC-CodeEditor id="CodeEditRegion3" expanded="true" visible="true" pixel-width="500" pixel-height="200" code-language="text/maple" autofit="true" wrapping="true" show-border="true" code-line-numbers="true">magic_mod := proc(A, p)
	local N, gen, u, v, res, last, new, i:
	N := RowDimension(A):
	gen := Generate(integer, makeproc = true):
	u := Vector[row](N, gen):
	v := Vector[column](N, gen):
	res := [LinearAlgebra:-Modular:-Multiply(p, u,  v)]:
	last := v:
	for i from 1 to 2*N do
		last := LinearAlgebra:-Modular:-Multiply(p, A, last):
		res := [ op(res) , LinearAlgebra:-Modular:-Multiply(p, u, last) ]:
	od:
	res
end proc:</EC-CodeEditor></CodeEditor-ExecGroup>
